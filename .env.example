# ============================================================
# EduCraft Solutions — Environment Configuration
# Copy this file to .env and fill in your real values.
# NEVER commit the .env file to Git.
# ============================================================

SECRET_KEY=change_me_to_a_long_random_string_here_64chars

# ── SMTP (Gmail) ─────────────────────────────────────────────
# Admin email: projecthubpshiksha@gmail.com
# 1. Google Account → Security → 2-Step Verification
# 2. App Passwords → Generate for "Mail"
# 3. Paste the 16-char password below (no spaces)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=projecthubpshiksha@gmail.com
SMTP_PASS=otlehwxxdwkolpba

# Admin receives all contact/enquiry/signup alerts
ADMIN_EMAIL=projecthubpshiksha@gmail.com

# ── Admin Login Credentials ───────────────────────────────────
ADMIN_EMAIL_LOGIN=projecthubpshiksha@gmail.com
ADMIN_PASSWORD=Admin@1234

# ── Google OAuth (for "Continue with Google" button) ─────────
# 1. Go to https://console.cloud.google.com
# 2. Create project → APIs & Services → Credentials
# 3. Create OAuth 2.0 Client ID (Web application)
# 4. Authorized redirect URI: http://localhost:5000/auth/google/callback
# 5. Copy Client ID and Secret below
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ── Google Sheets Live Data ───────────────────────────────────
# After setup (see GOOGLE_SHEETS_SETUP.md):
# Paste your Google Sheet URL here:
GOOGLE_SHEET_URL=https://docs.google.com/spreadsheets/d/1XHhRCfOqHGkcciPZctg5D4T5qy9Oy5Iny8v-MuUOQSM/edit?gid=0#gid=0

# Path to your service account JSON key file:
GSHEET_KEY_FILE=gsheet_credentials.json

# The name of the Google Sheet document:
GSHEET_NAME=EduCraft Live Data
